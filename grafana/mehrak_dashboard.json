      "targets": [
        {
          "datasource": {
            "uid": "Prometheus"
          },
          "editorType": "sql",
          "expr": "100 - (avg by (instance) (irate(node_cpu_seconds_total{mode=\"idle\"}[1m])) * 100)",
          "format": 1,
          "interval": "",
          "legendFormat": "CPU Usage %",
          "meta": {
            "builderOptions": {
              "columns": [],
              "database": "",
              "limit": 1000,
              "mode": "list",
              "queryType": "table",
              "table": ""
            }
          },
          "pluginVersion": "4.13.0",
          "queryType": "table",
          "rawSql": "SELECT\r\n  TimeUnix as time,\r\n  Attributes['cpu'] AS cpu_core,\r\n  100 * (1 - avg(Value)) AS cpu_utilization\r\nFROM otel_metrics_gauge\r\nWHERE\r\n  $__timeFilter(TimeUnix)\r\n  AND MetricName = 'system.cpu.utilization'\r\n  AND Attributes['state'] = 'idle'\r\nGROUP BY \r\n  time,\r\n  cpu_core\r\nORDER BY \r\n  TimeUnix,\r\n  cpu_core ASC",
          "refId": "CPU Utilization"
        }
      ],
      "title": "System CPU Usage",
      "transformations": [
        {
          "id": "prepareTimeSeries",
          "options": {
            "format": "multi"
          }
        }
      ],
      "type": "timeseries"
    },
