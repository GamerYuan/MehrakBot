          "editorMode": "code",
          "editorType": "sql",
          "exemplar": false,
          "expr": "(\r\n  sum(rate(discord_command_results{result=\"success\"}[5m])) \r\n  / \r\n  (sum(rate(discord_command_results[5m])) > 0) * 100\r\n) OR on() vector(100)",
          "format": 1,
          "instant": false,
          "interval": "",
          "legendFormat": "Success",
          "meta": {
            "builderOptions": {
              "columns": [],
              "database": "",
              "limit": 1000,
              "mode": "list",
              "queryType": "table",
              "table": ""
            }
          },
          "pluginVersion": "4.13.0",
          "queryType": "table",
          "range": true,
          "rawSql": "SELECT\r\n    time,\r\n    if(total_commands > 0, (success_commands / total_commands) * 100, 100) AS success_rate\r\nFROM\r\n(\r\n    SELECT\r\n        toStartOfInterval(TimeUnix, INTERVAL $__interval_s second) AS time,\r\n        sumIf(Value, Attributes['result'] = 'success') AS success_commands,\r\n        sum(Value) AS total_commands\r\n    FROM otel_metrics_sum\r\n    WHERE MetricName = 'bot_command_results'\r\n      AND $__timeFilter(TimeUnix)\r\n    GROUP BY time\r\n    ORDER BY time ASC WITH FILL STEP $__interval_s\r\n)",
          "refId": "A"
        }
      ],
      "title": "Command Success Rate",
      "type": "timeseries"
    },
