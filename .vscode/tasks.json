{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "build-application",
      "command": "dotnet",
      "type": "process",
      "args": [
        "build",
        "${workspaceFolder}/MehrakBot/Services/Application/Mehrak.Application/Mehrak.Application.csproj",
        "/property:GenerateFullPaths=true",
        "/consoleloggerparameters:NoSummary"
      ],
      "group": "build",
      "presentation": { "reveal": "silent" },
      "problemMatcher": "$msCompile"
    },
    {
      "label": "build-bot",
      "command": "dotnet",
      "type": "process",
      "args": [
        "build",
        "${workspaceFolder}/MehrakBot/Services/Bot/Mehrak.Bot/Mehrak.Bot.csproj",
        "/property:GenerateFullPaths=true",
        "/consoleloggerparameters:NoSummary"
      ],
      "group": "build",
      "presentation": { "reveal": "silent" },
      "problemMatcher": "$msCompile",
      "dependsOrder": "sequence"
    },
    {
      "label": "build-dashboard",
      "command": "dotnet",
      "type": "process",
      "args": [
        "build",
        "${workspaceFolder}/MehrakBot/Services/Dashboard/Mehrak.Dashboard/Mehrak.Dashboard.csproj",
        "/property:GenerateFullPaths=true",
        "/consoleloggerparameters:NoSummary"
      ],
      "group": "build",
      "presentation": { "reveal": "silent" },
      "problemMatcher": "$msCompile"
    },
    {
      "label": "build-image-processor",
      "command": "dotnet",
      "type": "process",
      "args": [
        "build",
        "${workspaceFolder}/MehrakBot/Services/ImageProcessor/Mehrak.ImageProcessor/Mehrak.ImageProcessor.csproj",
        "/property:GenerateFullPaths=true",
        "/consoleloggerparameters:NoSummary"
      ],
      "group": "build",
      "presentation": { "reveal": "silent" },
      "problemMatcher": "$msCompile"
    }
  ]
}
