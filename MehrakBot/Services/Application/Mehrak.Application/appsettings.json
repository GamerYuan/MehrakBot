{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "System": "Information",
      "Microsoft": "Information",
      "Microsoft.EntityFrameworkCore": "Warning",
      "Microsoft.EntityFrameworkCore.Database.Command": "Warning"
    }
  },
  "Kestrel": {
    "EndpointDefaults": {
      "Protocols": "Http2"
    }
  },
  "CommandDispatcher": {
    "MaxConcurrency": 10
  },
  "ConnectionStrings": {
    "redis": "redis:6379",
    "mehrakdb": "Host=postgres;Port=5432",
    "image-processor": "http://image-processor:13000"
  },
  "Redis": {
    "InstanceName": "Mehrak_"
  },
  "Storage": {
    "Bucket": "mehrak-assets",
    "ServiceURL": "http://seaweed-s3:8333",
    "AccessKey": "mehrak-bot",
    "SecretKey": "",
    "Region": "us-east-1",
    "ForcePathStyle": true
  },
  "AttachmentStorage": {
    "Bucket": "mehrak-attachments"
  }
}