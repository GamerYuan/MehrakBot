{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "System": "Information",
      "Microsoft": "Information",
      "Microsoft.EntityFrameworkCore": "Warning",
      "Microsoft.EntityFrameworkCore.Database.Command": "Warning"
    }
  },
  "Kestrel": {
    "Endpoints": {
      "MyHttpEndpoint": {
        "Url": "http://*:12000",
        "Protocols": "Http2"
      }
    }
  },
  "CommandDispatcher": {
    "MaxConcurrency": 10
  },
  "Redis": {
    "ConnectionString": "redis:6379",
    "InstanceName": "Mehrak_"
  },
  "Postgres": {
    "ConnectionString": "Host=postgres;Port=5432"
  },
  "Storage": {
    "Bucket": "mehrak-assets",
    "ServiceURL": "http://seaweed-s3:8333",
    "AccessKey": "mehrak-bot",
    "SecretKey": "",
    "Region": "us-east-1",
    "ForcePathStyle": true
  },
  "AttachmentStorage": {
    "Bucket": "mehrak-attachments"
  },
  "CharacterCache": {
    "UpdateInterval": "01:00:00",
    "EnablePeriodicUpdates": true,
    "EnableInitialPopulation": true
  },
  "Otlp": {
    "Endpoint": "http://otel-collector:4317"
  }
}
