{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "Kestrel": {
    "Endpoints": {
      "MyHttpEndpoint": {
        "Url": "http://*:5000"
      }
    }
  },
  "Application": {
    "ConnectionString": "http://application:12000"
  },
  "Dashboard": {
    "AdminUsername": "",
    "AdminPassword": "",
    "AdminDiscordId": "",
    "Origin": ""
  },
  "Postgres": {
    "ConnectionString": "Host=postgres;Port=5432"
  },
  "Redis": {
    "ConnectionString": "redis:6379",
    "InstanceName": "Mehrak_"
  },
  "Storage": {
    "Bucket": "mehrak-assets",
    "ServiceURL": "http://seaweed-s3:8333",
    "AccessKey": "mehrak-bot",
    "SecretKey": "",
    "Region": "us-east-1",
    "ForcePathStyle": true
  },
  "SeaweedFiler": {
    "BaseUrl": "http://seaweed-filer:8888"
  },
  "AttachmentStorage": {
    "Bucket": "mehrak-attachments"
  },
  "CharacterCache": {
    "UpdateInterval": "00:00:00",
    "EnablePeriodicUpdates": false,
    "EnableInitialPopulation": false
  },
  "Nginx": {
    "KnownProxy": ""
  },
  "Otlp": {
    "Endpoint": "http://otel-collector:4317"
  }
}
